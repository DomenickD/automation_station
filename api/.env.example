# When running via start.sh / Docker Compose, DATABASE_URL is overridden by
# docker-compose.yml to use the "postgres" service hostname automatically.
# This value is used only if you run the API outside Docker (e.g. bare uvicorn).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/automation_station
ANTHROPIC_API_KEY=sk-ant-...
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:5173

# ── Environment ───────────────────────────────────────────────
# "development" → uses local Ollama (gemma4:e4b) instead of Claude API
# "production"  → uses Anthropic Claude API (requires ANTHROPIC_API_KEY)
ENV=development

# ── Ollama (dev only) ─────────────────────────────────────────
# start.sh spins up the Docker container automatically in dev mode.
# Override these only if you run Ollama yourself outside Docker.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Optional: enables automated CMA comp research.
# Without this key, the app shows verification search links instead.
TAVILY_API_KEY=
